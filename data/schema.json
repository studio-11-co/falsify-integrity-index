{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/studio-11-co/falsify-integrity-index/blob/main/data/schema.json",
  "title": "PRML Integrity Index entry schema",
  "type": "object",
  "required": ["version", "generated", "criteria_order", "entries"],
  "properties": {
    "version": { "type": "string", "pattern": "^[0-9]{4}-Q[1-4]$" },
    "generated": { "type": "string", "format": "date" },
    "schema": { "type": "string" },
    "criteria_order": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 9,
      "maxItems": 9
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "source", "url", "bits", "note"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" },
          "bits": {
            "type": "array",
            "items": { "type": "integer", "enum": [0, 1] },
            "minItems": 9,
            "maxItems": 9
          },
          "note": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
